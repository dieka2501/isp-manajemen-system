APP_NAME=ISP Manajemen Backend
APP_ENV=development
APP_VERSION=
APP_BUILD_COMMIT=
APP_BUILD_BRANCH=
APP_DEBUG=true
APP_HOST=127.0.0.1:8000
API_V1_PREFIX=/api/v1
FONNTE_API_URL=https://api.fonnte.com/send
FONNTE_TOKEN=
FONNTE_DEFAULT_COUNTRY_CODE=62
FONNTE_WEBHOOK_SECRET=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=20
LLM_RESPONSE_ENABLED=true
CONVERSATION_STATE_TTL_HOURS=48
CHAT_DATABASE_PATH=data/chat.sqlite3
CHAT_AUTO_ACCOUNT_NAME=Auto Ingest Account
CHAT_AUTO_ACCOUNT_SLUG=auto-ingest
SQLITE_EXPLORER_SOURCES_JSON=[{"name":"Chat Database","path":"data/chat.sqlite3"}]
DASHBOARD_SECRET=
DASHBOARD_COOKIE_NAME=sqlite_dashboard_session
DASHBOARD_SESSION_HOURS=12
CLIENT_DASHBOARD_JWT_SECRET=
CLIENT_DASHBOARD_TOKEN_HOURS=2
CLIENT_DASHBOARD_SEED_EMAIL=admin@isp.local
CLIENT_DASHBOARD_SEED_PASSWORD=password
CLIENT_DASHBOARD_SEED_OFFICE_ADDRESS=Kantor ISP
CLIENT_DASHBOARD_SEED_PIC_NAME=Admin ISP
BILLING_SAMPLE_XLSX_PATH=contoh-list-billing.xlsx
